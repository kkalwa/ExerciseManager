<UserControl x:Class="ExerciseManager.Views.CreateNewSetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExerciseManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" TextAlignment="Center" FontSize="20" FontWeight="SemiBold" Margin="10" Text="Tworzenie nowego zestawu ćwiczeń"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Right" TextAlignment="Center" FontSize="12" Margin="10" Text="Wprowadź nazwę zestawu ćwiczeń"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment ="Bottom" HorizontalAlignment="Right" TextAlignment="Center" FontSize="12" Margin="10" Text="Wprowadź ćwiczenia do zestawu"/>
        <TextBox Grid.Row="1" Grid.Column="2"  Margin="10" VerticalAlignment="Top"  Text="{Binding ExerciseSetTitle, Mode=TwoWay}"/>


        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Grid.ColumnSpan="7">
            <TextBlock VerticalAlignment="Top" Width="75" Text="Nazwa" />
            <TextBlock VerticalAlignment="Top" Width="30" Text="Seria 1"/>
            <TextBlock VerticalAlignment="Top" Width="30" Text="Seria 2"/>
            <TextBlock VerticalAlignment="Top" Width="30" Text="Seria 3"/>
            <TextBlock VerticalAlignment="Top" Width="30" Text="Seria 4"/>
            <TextBlock VerticalAlignment="Top" Width="30" Text="Seria 5"/>
        </StackPanel>
        
        <ItemsControl Grid.Row="3" Grid.Column="0"  Grid.ColumnSpan="7" Grid.RowSpan="5" VerticalAlignment="Top" ItemsSource="{Binding Exercises}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="75" Text="{Binding ExerciseName}"/>
                        <ItemsControl ItemsSource="{Binding ExerciseWeights}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBox Width="30"  Text="{Binding Path=. , Mode=TwoWay}"/>
                                        <!-- Path=. Not really sure if this is the right way to bind -->
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Grid.Row="6" Command="{Binding AddExerciseCommand}" Content="Dodaj zestaw" HorizontalAlignment="Left" Margin="10"/>
        <Button Grid.Row="6" Grid.Column="1" Command="{Binding AddNewLineCommand}" Content="Dodaj ćwiczenie" HorizontalAlignment="Left" Margin="10"/>
        <Button Grid.Row="6" Grid.Column="2" Command="{Binding RemoveLineCommand}" Content="Usuń ćwiczenie" HorizontalAlignment="Left" Margin="10"/>
    </Grid>
</UserControl>
