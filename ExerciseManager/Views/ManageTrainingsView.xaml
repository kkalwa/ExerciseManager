<UserControl x:Class="ExerciseManager.Views.ManageTrainingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExerciseManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
            <StackPanel Grid.Column="0" Width="Auto">
            <TextBlock Margin="5" Text="Wybierz zestawy do swojego treningu"/>
            <ScrollViewer Width="auto" Height="300">
            <ListBox  SelectedItem="{Binding SelectedItem}" ItemsSource="{Binding ExerciseSetsList}" BorderThickness="3">
                <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Background="AliceBlue" Margin="10" Width="auto">
                                
                                    <TextBlock Text="{Binding ExerciseSetTitle}" Background="DarkOrange" TextAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                                    
                                <ItemsControl ItemsSource="{Binding Exercises}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ExerciseName}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </StackPanel>

        <Button Grid.Column="1" Content="Dodaj do treningu" Margin="5" Padding="5" Command="{Binding AddToTrainingCommand}"/>

        <StackPanel Grid.Column="2">
            <TextBlock Margin="5" Text="Wybrałeś nastepujące zestawy:"/>
            <ListBox   ItemsSource="{Binding SelectedExerciseSetsList}" BorderThickness="3" Width="auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Background="AliceBlue" Margin="10" Width="auto">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ExerciseSetTitle}" Background="DarkOrange" TextAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                                <Button Content="+" Width="100"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Exercises}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ExerciseName}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
        <Button Grid.Row="1" Grid.Column="1" Content="Zatwierdź" Width="100" Height="30" Command="{Binding ConfirmTrainingCommand}"/>
    </Grid>
</UserControl>
